<UserControl x:Class="Liekinheitin.RoutingHost.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Liekinheitin.RoutingHost.Views"
             xmlns:sup="clr-namespace:Liekinheitin.Infrastructure.Supervision;assembly=Liekinheitin.Infrastructure"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#14171C">

    <UserControl.Resources>
        <Style x:Key="LevelBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Background" Value="#5B6472" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="{x:Static sup:LogLevel.Error}">
                    <Setter Property="Background" Value="#EF4444" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="{x:Static sup:LogLevel.Warning}">
                    <Setter Property="Background" Value="#F5A524" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Journal" Foreground="#E8E6DF" FontWeight="SemiBold" FontSize="14"
                       VerticalAlignment="Center" />
            <Button Content="Effacer" DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Click="ClearButton_Click"
                    Background="#1F2530" Foreground="#E8E6DF" BorderBrush="#2B3240"
                    Padding="10,4" Cursor="Hand" />
        </DockPanel>

        <ListView x:Name="LogList"
                  Background="#14171C" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="0,3" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type sup:LogEntry}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                   Foreground="#838A99" FontFamily="Consolas" FontSize="12"
                                   Width="70" VerticalAlignment="Center" />
                        <Border Style="{StaticResource LevelBadgeStyle}" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Level}" Foreground="White" FontSize="10.5" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{Binding Source}" Foreground="#E8E6DF" FontFamily="Consolas" FontSize="12"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Message}" Foreground="#B7BCC6" FontFamily="Consolas" FontSize="12"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</UserControl>
