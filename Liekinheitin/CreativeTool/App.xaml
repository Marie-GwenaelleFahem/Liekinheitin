<Application x:Class="Liekinheitin.CreativeTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Liekinheitin.CreativeTool"
             xmlns:converters="clr-namespace:Liekinheitin.CreativeTool.Converters">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#FF2A2D34" />
        <SolidColorBrush x:Key="PanelTitleBackground" Color="#FF3A3D44" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="Gray" />

        <converters:ColorToBrushConverter x:Key="ColorToBrush" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="BoolToVisInverse" />
    </Application.Resources>
</Application>
