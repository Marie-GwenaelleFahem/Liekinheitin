<UserControl x:Class="Liekinheitin.CreativeTool.Views.PixelGridCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" AllowDrop="True" Drop="OnDrop"
          KeyDown="OnKeyDown" Focusable="True">
        <Image x:Name="GridImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               MouseLeftButtonDown="OnMouseDown"
               MouseMove="OnMouseMove" />
        <Canvas x:Name="ShapeOverlay" IsHitTestVisible="True" Background="Transparent" />
    </Grid>
</UserControl>