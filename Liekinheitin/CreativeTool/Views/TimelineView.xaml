<UserControl x:Class="Liekinheitin.CreativeTool.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelTitleBackground}" Padding="4">
                <Grid>
                    <TextBlock Text="Timeline" Foreground="White" FontWeight="Bold" />
                    <Button Content="Plein écran" Click="OnFullscreenClick" HorizontalAlignment="Right" Padding="8,2" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8">
                <Button Content="Lecture" Click="OnPlayPauseClick" Margin="0,0,4,0" Padding="8,4" />
                <Button Content="Stop" Click="OnStopClick" Margin="0,0,4,0" Padding="8,4" />
                <Button Content="Keyframe (forme sélectionnée)" Click="OnAddKeyframeClick" Margin="0,0,12,0" Padding="8,4" />
                <TextBlock Text="Durée (s)" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox x:Name="DurationBox" Text="{Binding TotalDuration, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,12,0" />
                <TextBlock x:Name="TimeLabel" Text="0.00s" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>

            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
                <Grid x:Name="ContentGrid"
                    MouseLeftButtonDown="OnContentGridMouseDown"
                    MouseMove="OnContentGridMouseMove"
                    MouseLeftButtonUp="OnContentGridMouseUp">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>