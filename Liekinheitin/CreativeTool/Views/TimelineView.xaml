<UserControl x:Class="Liekinheitin.CreativeTool.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
        <StackPanel>
            <Border Background="{StaticResource PanelTitleBackground}" Padding="4">
                <TextBlock Text="Timeline" Foreground="White" FontWeight="Bold" />
            </Border>

            <StackPanel Orientation="Horizontal" Margin="8">
                <Button x:Name="PlayPauseButton" Content="Lecture" Click="OnPlayPauseClick" Margin="0,0,4,0" Padding="8,4" />
                <Button Content="Stop" Click="OnStopClick" Margin="0,0,4,0" Padding="8,4" />
                <Button Content="Ajouter keyframe (forme sélectionnée)" Click="OnAddKeyframeClick" Padding="8,4" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="8,0,8,8">
                <TextBlock Text="Durée (s)" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Text="{Binding TotalDuration, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,12,0" />

                <Slider x:Name="Scrubber" Minimum="0" Maximum="{Binding Duration}"
                    Value="{Binding CurrentTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="350" Margin="0,0,8,0" IsMoveToPointEnabled="True" />
                <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:0.00}s'}" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>