<UserControl x:Class="Liekinheitin.CreativeTool.Views.ShapeInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220"
             Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
    <Border Background="#FF2A2D34" BorderBrush="Gray" BorderThickness="1">
        <StackPanel Margin="8">
            <Border x:Name="TitleBar" Background="#FF3A3D44" Padding="4"
                    MouseLeftButtonDown="OnTitleBarMouseDown"
                    MouseMove="OnTitleBarMouseMove"
                    MouseLeftButtonUp="OnTitleBarMouseUp">
                <TextBlock Text="Propriétés de la forme" Foreground="White" FontWeight="Bold" />
            </Border>

            <TextBlock Text="{Binding IdText, StringFormat='Id : {0}'}" Foreground="Gray" FontSize="10" Margin="0,6,0,4" />

            <TextBlock Text="Position X" Foreground="White" />
            <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

            <TextBlock Text="Position Y" Foreground="White" />
            <TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

            <TextBlock Text="Width" Foreground="White" />
            <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

            <TextBlock Text="Height" Foreground="White" />
            <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

            <TextBlock Text="Scale" Foreground="White" />
            <Slider Minimum="0.1" Maximum="5" Value="{Binding Scale}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Scale, StringFormat='{}{0:0.00}'}" Foreground="Gray" FontSize="10" Margin="0,0,0,4" />

            <TextBlock Text="Couleur" Foreground="White" />
            <Rectangle Height="20" Fill="{Binding CurrentColor, Converter={StaticResource ColorToBrush}}" Margin="0,0,0,4" />

            <TextBlock Text="R" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding ColorR}" />
            <TextBlock Text="G" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding ColorG}" />
            <TextBlock Text="B" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding ColorB}" />
        </StackPanel>
    </Border>
</UserControl>