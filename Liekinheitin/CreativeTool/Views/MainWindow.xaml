<Window x:Class="Liekinheitin.CreativeTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Liekinheitin.CreativeTool.Views"
        mc:Ignorable="d"
        Title="Liekinheitin Creative Tool"
        Height="800"
        Width="1280"
        MinHeight="640"
        MinWidth="980"
        Background="#1F1F1F">
    <Window.Resources>
        <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" Background="#2B2B2B" Foreground="#F4F4F4">
            <MenuItem Header="_Fichier" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="_Nouveau projet" Click="OnNewProjectClick" />
                <MenuItem Header="_Ouvrir..." Click="OnOpenProjectClick" />
                <Separator />
                <MenuItem Header="_Sauvegarder" Click="OnSaveProjectClick" />
                <MenuItem Header="Sauvegarder _sous..." Click="OnSaveProjectAsClick" />
                <Separator />
                <MenuItem Header="_Quitter" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edition" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="Annuler" IsEnabled="False" />
                <MenuItem Header="Retablir" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="_Lecture" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="Play" Click="OnPlayClick" />
                <MenuItem Header="Pause" Click="OnPauseClick" />
                <MenuItem Header="Stop" Click="OnStopClick" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#2B2B2B" Foreground="#DADADA">
            <StatusBarItem x:Name="PlaybackStatusItem" Content="Pret" />
            <Separator />
            <StatusBarItem x:Name="ProjectStatusItem" Content="Projet non sauvegarde" />
            <Separator />
            <StatusBarItem x:Name="WallStatusItem" Content="128 x 128" />
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="260" MinHeight="140" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1"
                    Background="#252525"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PlayButton" Width="72" Margin="0,0,8,0" Content="Play" />
                        <Button x:Name="PauseButton" Width="72" Margin="0,0,8,0" Content="Pause" />
                        <Button x:Name="StopButton" Width="72" Content="Stop" />
                    </StackPanel>

                    <Slider x:Name="TimeSlider" Grid.Column="1"
                            Margin="20,0"
                            Minimum="0"
                            Maximum="30"
                            Value="0"
                            VerticalAlignment="Center" />

                    <TextBlock x:Name="TimeDisplayText" Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#F4F4F4"
                               FontFamily="Consolas"
                               Text="00:00.000 / 00:30.000" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#151515">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Margin="12,10"
                               Foreground="#DADADA"
                               FontWeight="SemiBold"
                               Text="Preview LED" />

                    <local:PixelGridView x:Name="LedPreview" Grid.Row="1" Margin="12" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1,0,0,0"
                    Background="#252525"
                    Padding="16">
                <TabControl Background="#252525"
                            BorderBrush="#3A3A3A"
                            Foreground="#F4F4F4">
                    <TabItem Header="Clip">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,16"
                                           Foreground="#F4F4F4"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Proprietes du clip" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Nom" />
                                <TextBox x:Name="ClipNameTextBox" Margin="0,4,0,12" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Debut" />
                                        <TextBox x:Name="ClipStartTextBox" Margin="0,4,0,0" Text="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Duree" />
                                        <TextBox x:Name="ClipDurationTextBox" Margin="0,4,0,0" Text="1" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Type d'effet" />
                                <ComboBox x:Name="EffectTypeComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="Couleur fixe" Tag="SolidColor" />
                                    <ComboBoxItem Content="Fade" Tag="Fade" />
                                    <ComboBoxItem Content="Wave" Tag="Wave" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Cible" />
                                <ComboBox x:Name="TargetTypeComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="Mur complet" Tag="FullWall" />
                                    <ComboBoxItem Content="Selection" Tag="Selection" />
                                    <ComboBoxItem Content="Piste" Tag="Track" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="RGBW" />
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="RedTextBox" Text="255" />
                                    <TextBox x:Name="GreenTextBox" Grid.Column="2" Text="255" />
                                    <TextBox x:Name="BlueTextBox" Grid.Column="4" Text="255" />
                                    <TextBox x:Name="WhiteTextBox" Grid.Column="6" Text="0" />
                                </Grid>

                                <local:ColorPickerView x:Name="ColorPickerControl" Margin="0,0,0,16" Height="140" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Intensite" />
                                <Slider x:Name="IntensitySlider" Margin="0,4,0,12" Minimum="0" Maximum="1" Value="1" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Vitesse" />
                                <Slider x:Name="SpeedSlider" Margin="0,4,0,20" Minimum="0" Maximum="4" Value="1" />

                                <Button x:Name="ApplyPropertiesButton" Height="34" Content="Appliquer les proprietes" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="ShapesTab" Header="Formes">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock x:Name="ShapesClipTextBlock"
                                           Margin="0,0,0,12"
                                           Foreground="#DADADA"
                                           Text="Aucun clip selectionne" />

                                <TextBlock x:Name="ShapeWorkflowTextBlock"
                                           Margin="0,0,0,12"
                                           Foreground="#AFAFAF"
                                           Text="Clique une forme, puis déplace son arrivée pour l'animer" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Souris dans le preview" />
                                <ComboBox x:Name="ShapeEditModeComboBox"
                                          Margin="0,4,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Déplacer le départ" Tag="Position" />
                                    <ComboBoxItem Content="Déplacer l'arrivée" Tag="Movement" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Trajet" />
                                <ComboBox x:Name="MovementEffectComboBox"
                                          Margin="0,4,0,8"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Aucun" Tag="None" />
                                    <ComboBoxItem Content="Instantané" Tag="Snap" />
                                    <ComboBoxItem Content="Impact" Tag="Punch" />
                                    <ComboBoxItem Content="Très rapide" Tag="VeryFast" />
                                    <ComboBoxItem Content="Rapide" Tag="Fast" />
                                    <ComboBoxItem Content="Lent" Tag="Slow" />
                                    <ComboBoxItem Content="Fade" Tag="Fade" />
                                </ComboBox>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MovementDurationTextBlock"
                                                   Foreground="#AFAFAF"
                                                   FontFamily="Consolas"
                                                   Text="durée 0.000s" />
                                        <TextBlock x:Name="MovementOffsetTextBlock"
                                                   Foreground="#AFAFAF"
                                                   FontFamily="Consolas"
                                                   Text="arrivée dx 0 / dy 0" />
                                    </StackPanel>
                                    <Button x:Name="ResetMovementButton"
                                            Grid.Column="2"
                                            MinWidth="72"
                                            Height="28"
                                            Content="Remise 0" />
                                </Grid>

                                <UniformGrid Columns="3" Margin="0,0,0,14">
                                    <Button x:Name="ReplayMotionButton"
                                            Height="30"
                                            Margin="0,0,6,0"
                                            Content="Rejouer" />
                                    <Button x:Name="RedoMotionButton"
                                            Height="30"
                                            Margin="0,0,6,0"
                                            Content="Refaire" />
                                    <Button x:Name="ConfirmMotionButton"
                                            Height="30"
                                            Content="Confirmer" />
                                </UniformGrid>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}"
                                           Margin="0,0,0,12"
                                           Text="Créer une barre de forme" />

                                <ItemsControl x:Name="ShapesItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,8"
                                                    Height="32"
                                                    HorizontalContentAlignment="Left"
                                                    Content="{Binding DisplayName}"
                                                    Tag="{Binding}"
                                                    Click="OnShapeButtonClick" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Row="2"
                          Grid.Column="0"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#2C2C2C"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="3"
                    Grid.Column="0"
                    Margin="12,0,12,12"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#181818">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="12,8,12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#DADADA"
                                   FontWeight="SemiBold"
                                   Text="Timeline" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#BEBEBE"
                                       FontSize="12"
                                       Text="Duree" />
                            <TextBox x:Name="ProjectDurationTextBox"
                                     Width="56"
                                     Height="24"
                                     Margin="8,0,0,0"
                                     Text="30" />
                        </StackPanel>
                        <Button x:Name="ApplyDurationButton"
                                Grid.Column="3"
                                MinWidth="72"
                                Height="26"
                                Content="Appliquer" />
                        <Button x:Name="ExtendTimelineButton"
                                Grid.Column="5"
                                MinWidth="52"
                                Height="26"
                                Content="+10s" />
                        <Button x:Name="AddShapeLayerButton"
                                Grid.Column="7"
                                MinWidth="104"
                                Height="26"
                                Content="+ Forme" />
                    </Grid>

                    <local:TimelineView x:Name="TimelineControl" Grid.Row="1" Margin="12" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
