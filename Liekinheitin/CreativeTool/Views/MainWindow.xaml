<Window x:Class="Liekinheitin.CreativeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Liekinheitin.CreativeTool.Views"
        Title="Liekinheitin - CreativeTool" Height="700" Width="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- bouton Test orientation -->
            <RowDefinition Height="7*" />
            <!-- grille + sidebar -->
            <RowDefinition Height="Auto" />
            <RowDefinition  Height="3*" />
            <RowDefinition x:Name="TimelineRow" Height="Auto"/>
            <!-- formes, pleine largeur -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <!-- grille -->
                <ColumnDefinition Width="1*" />
                <!-- sidebar : couleur + colonnes -->
            </Grid.ColumnDefinitions>

            <views:PixelGridCanvasView x:Name="GridView" Grid.Column="0" />

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- couleur -->
                    <RowDefinition Height="*" />
                    <!-- colonnes, prend le reste -->
                </Grid.RowDefinitions>

                <views:ColorPickerView Grid.Row="0"
                                        DataContext="{Binding ColorPicker}"
                                        Width="Auto" HorizontalAlignment="Stretch" />

                <views:ColumnListView x:Name="ColumnList" Grid.Row="1"
                       DataContext="{Binding ColumnList}"
                       Width="Auto" HorizontalAlignment="Stretch" />
            </Grid>
        </Grid>

        <views:ShapeListView x:Name="ShapeList" Grid.Row="2" Grid.ColumnSpan="1"
                               DataContext="{Binding ShapeList}"
                               Width="Auto" HorizontalAlignment="Stretch" />
        <views:AudioControlView DataContext="{Binding Audio}" Grid.Row="2" Margin="0,4,0,0" />
        <views:TimelineView x:Name="TimelineViewControl" Grid.Row="3" DataContext="{Binding TimelineViewModel}" Margin="0,4,0,0" />
        <views:FixtureControlView x:Name="FixtureControl" Grid.Row="4" DataContext="{Binding FixtureControl}" Margin="0,4,0,0" />

        <Canvas Grid.Row="1" Grid.RowSpan="2">
            <views:ShapeInspectorView x:Name="Inspector" DataContext="{Binding ShapeInspector}"
                               Canvas.Left="600" Canvas.Top="60" />
            <views:FixtureInspectorView x:Name="FixtureInspector" DataContext="{Binding FixtureControl.Inspector}"
                                 Canvas.Left="850" Canvas.Top="60" />
        </Canvas>
    </Grid>
</Window>