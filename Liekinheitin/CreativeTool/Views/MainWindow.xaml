<Window x:Class="Liekinheitin.CreativeTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Liekinheitin.CreativeTool.Views"
        mc:Ignorable="d"
        Title="Liekinheitin Creative Tool"
        Height="940"
        Width="1500"
        MinHeight="720"
        MinWidth="1180"
        FontFamily="Segoe UI"
        Background="#070B12">
    <Window.Resources>
        <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="ShapeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="Background" Value="#343A46" />
            <Setter Property="BorderBrush" Value="#566277" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="7" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#46536A" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#8296B8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#283142" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Chrome" Property="Opacity" Value="0.4" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource ShapeButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F3F7FF" />
            <Setter Property="Background" Value="#111A28" />
            <Setter Property="BorderBrush" Value="#2B3D55" />
            <Setter Property="CaretBrush" Value="#62E6FF" />
            <Setter Property="SelectionBrush" Value="#376D80" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A8B7CA" />
                    <Setter Property="Background" Value="#202A38" />
                    <Setter Property="BorderBrush" Value="#344257" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#0E1826" />
            <Setter Property="BorderBrush" Value="#4B607A" />
            <Setter Property="Padding" Value="7,4" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#62E6FF" />
                    <Setter Property="Background" Value="#13263A" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#A8B7CA" />
                    <Setter Property="Background" Value="#202A38" />
                    <Setter Property="BorderBrush" Value="#344257" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F7FAFF" />
            <Setter Property="Background" Value="#101B2A" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="OptionBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#263A52"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="OptionBackground" Property="Background" Value="#24516A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OptionBackground" Property="Background" Value="#1D6681" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OptionBackground" Property="Background" Value="#202A38" />
                                <Setter Property="Foreground" Value="#8D9BAE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F4F7FC" />
            <Setter Property="Background" Value="#111A28" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#0D1420" />
            <Setter Property="BorderBrush" Value="#25364C" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#AAB7C9" />
            <Setter Property="Background" Value="#111A28" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#62E6FF" />
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" Height="32" Background="#0A101A" Foreground="#DCE7F6">
            <MenuItem Header="_Fichier" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="_Nouveau projet" Click="OnNewProjectClick" />
                <MenuItem Header="_Ouvrir..." Click="OnOpenProjectClick" />
                <Separator />
                <MenuItem Header="_Sauvegarder" Click="OnSaveProjectClick" />
                <MenuItem Header="Sauvegarder _sous..." Click="OnSaveProjectAsClick" />
                <MenuItem Header="Enregistrer dans _Mes sauvegardes" Click="OnSaveToLibraryClick" />
                <MenuItem Header="_Mes sauvegardes..." Click="OnSavedProjectsClick" />
                <Separator />
                <MenuItem Header="_Quitter" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edition" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="Annuler" IsEnabled="False" />
                <MenuItem Header="Retablir" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="_Lecture" Foreground="#F4F4F4" Background="#2B2B2B">
                <MenuItem Header="Play" Click="OnPlayClick" />
                <MenuItem Header="Pause" Click="OnPauseClick" />
                <MenuItem Header="Stop" Click="OnStopClick" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#0A101A" Foreground="#92A4BC" BorderBrush="#1D3044" BorderThickness="0,1,0,0">
            <StatusBarItem x:Name="PlaybackStatusItem" Content="Pret" />
            <Separator />
            <StatusBarItem x:Name="ProjectStatusItem" Content="Projet non sauvegarde" />
            <Separator />
            <StatusBarItem x:Name="WallStatusItem" Content="128 x 128" />
            <Separator />
            <StatusBarItem x:Name="ActionFeedbackItem" Foreground="#62E6FF" Content="STUDIO PRÊT" />
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="330" MinHeight="190" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    BorderBrush="#1D3F52"
                    BorderThickness="0,0,0,1"
                    Background="#0D1522"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Foreground="#F3F7FF" FontSize="15" FontWeight="Bold" Text="LIEKINHEITIN // STUDIO" />
                            <TextBlock Foreground="#5B728E" FontSize="9" Text="LIVE LED PERFORMANCE CONSOLE" />
                        </StackPanel>
                        <Button x:Name="PlayButton" Width="62" Margin="0,0,6,0" Background="#123C3B" BorderBrush="#22B8A7" Content="▶ PLAY" />
                        <Button x:Name="PauseButton" Width="64" Margin="0,0,6,0" Background="#3A3018" BorderBrush="#D09B2E" Content="Ⅱ PAUSE" />
                        <Button x:Name="StopButton" Width="58" Background="#3D1C2A" BorderBrush="#D45079" Content="■ STOP" />
                    </StackPanel>

                    <Slider x:Name="TimeSlider" Grid.Column="1"
                            Margin="20,0"
                            Minimum="0"
                            Maximum="30"
                            Value="0"
                            VerticalAlignment="Center" />

                    <TextBlock x:Name="TimeDisplayText" Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#F4F4F4"
                               FontFamily="Consolas"
                               Text="00:00.000 / 00:30.000" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="12"
                    BorderBrush="#23465A"
                    BorderThickness="1"
                    Background="#080E17"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="14,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="#F3F7FF" FontSize="15" FontWeight="Bold" Text="LED STAGE // 128 × 128" />
                            <TextBlock Foreground="#60758E" FontSize="10" Text="TRANSFORM · MOVE · SCALE · ROTATE" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Height="26" Margin="0,0,6,0" Padding="9,0" Tag="Position" Click="OnPreviewToolClick" Content="↔ MOVE" />
                            <Button Height="26" Margin="0,0,6,0" Padding="9,0" Tag="Resize" Click="OnPreviewToolClick" Content="⤢ SCALE" />
                            <Button Height="26" Margin="0,0,10,0" Padding="9,0" Tag="Rotate" Click="OnPreviewToolClick" Content="⟳ ROTATE" />
                            <Border Margin="0,0,8,0" Padding="9,4" CornerRadius="10" Background="#172B35" BorderBrush="#2C6B7E" BorderThickness="1">
                                <TextBlock Foreground="#62E6FF" FontSize="10" Text="PREVIEW LIVE" />
                            </Border>
                            <Border Padding="9,4" CornerRadius="10" Background="#251B35" BorderBrush="#644588" BorderThickness="1">
                                <TextBlock Foreground="#D59CFF" FontSize="10" Text="PIXEL PERFECT" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="12" ClipToBounds="True">
                        <local:PixelGridView x:Name="LedPreview" />
                        <Image x:Name="MediaImageOverlay" Stretch="Uniform" Cursor="SizeAll" Visibility="Collapsed" />
                        <MediaElement x:Name="MediaVideoOverlay" Stretch="Uniform" IsHitTestVisible="False"
                                      LoadedBehavior="Manual" UnloadedBehavior="Manual" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    BorderBrush="#22384E"
                    BorderThickness="1,0,0,0"
                    Background="#0D1420"
                    Padding="16">
                <TabControl Background="#0D1420"
                            BorderBrush="#25364C"
                            Foreground="#F4F4F4">
                    <TabItem Header="MIXER">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,16"
                                           Foreground="#F4F4F4"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Proprietes du clip" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Nom" />
                                <TextBox x:Name="ClipNameTextBox" Margin="0,4,0,12" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Debut" />
                                        <TextBox x:Name="ClipStartTextBox" Margin="0,4,0,0" Text="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Duree" />
                                        <TextBox x:Name="ClipDurationTextBox" Margin="0,4,0,0" Text="1" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Type d'effet" />
                                <ComboBox x:Name="EffectTypeComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="Couleur fixe" Tag="SolidColor" />
                                    <ComboBoxItem Content="Fade" Tag="Fade" />
                                    <ComboBoxItem Content="Wave" Tag="Wave" />
                                    <ComboBoxItem Content="Pulse" Tag="Pulse" />
                                    <ComboBoxItem Content="Stroboscope" Tag="Strobe" />
                                    <ComboBoxItem Content="Chaser DJ" Tag="Chase" />
                                    <ComboBoxItem Content="Respiration" Tag="Breath" />
                                    <ComboBoxItem Content="Étincelles" Tag="Sparkle" />
                                    <ComboBoxItem Content="Égaliseur" Tag="Equalizer" />
                                    <ComboBoxItem Content="Ondes concentriques" Tag="Ripple" />
                                    <ComboBoxItem Content="Anneau d'impact plein écran" Tag="ClickRipple" />
                                    <ComboBoxItem Content="Tracé cardiaque dessiné" Tag="HeartbeatTrace" />
                                    <ComboBoxItem Content="Braises descendantes" Tag="FallingEmbers" />
                                    <ComboBoxItem Content="Lignes blanches descendantes" Tag="WhiteFallingLines" />
                                    <ComboBoxItem Content="Ondulation — contraction et explosion" Tag="ContractExplodeRipple" />
                                </ComboBox>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Centre ondulation X" />
                                        <TextBox x:Name="RippleCenterXTextBox" Margin="0,4,0,0" Text="64" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Centre ondulation Y" />
                                        <TextBox x:Name="RippleCenterYTextBox" Margin="0,4,0,0" Text="64" />
                                    </StackPanel>
                                </Grid>
                                <Button x:Name="AddOrganicRippleButton"
                                        Height="32"
                                        Margin="0,0,0,12"
                                        Background="#18394A"
                                        BorderBrush="#3D9CC0"
                                        Content="+ Créer une ondulation organique" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Cible" />
                                <ComboBox x:Name="TargetTypeComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="Mur complet" Tag="FullWall" />
                                    <ComboBoxItem Content="Selection" Tag="Selection" />
                                    <ComboBoxItem Content="Piste" Tag="Track" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="RGBW" />
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="RedTextBox" Text="255" />
                                    <TextBox x:Name="GreenTextBox" Grid.Column="2" Text="255" />
                                    <TextBox x:Name="BlueTextBox" Grid.Column="4" Text="255" />
                                    <TextBox x:Name="WhiteTextBox" Grid.Column="6" Text="0" />
                                </Grid>

                                <local:ColorPickerView x:Name="ColorPickerControl" Margin="0,0,0,16" Height="140" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Intensite" />
                                <Slider x:Name="IntensitySlider" Margin="0,4,0,12" Minimum="0" Maximum="1" Value="1" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Vitesse" />
                                <Slider x:Name="SpeedSlider" Margin="0,4,0,20" Minimum="0" Maximum="10" Value="1" />

                                <Button x:Name="ApplyPropertiesButton" Height="34" Content="Appliquer les proprietes" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="LYRES">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Foreground="#F4F4F4" FontSize="16" FontWeight="SemiBold" Text="Pilotage direct des lyres" />
                                <TextBlock Margin="0,4,0,16" Foreground="#8195AE" FontSize="10" TextWrapping="Wrap"
                                           Text="Réglez une lyre ou les quatre, puis envoyez immédiatement la commande DMX." />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Appareil" />
                                <ComboBox x:Name="LyreTargetComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="Les 4 lyres" Tag="0" />
                                    <ComboBoxItem Content="Lyre 1" Tag="2" />
                                    <ComboBoxItem Content="Lyre 2" Tag="3" />
                                    <ComboBoxItem Content="Lyre 3" Tag="4" />
                                    <ComboBoxItem Content="Lyre 4" Tag="5" />
                                </ComboBox>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Pan" />
                                <Slider x:Name="LyrePanSlider" Margin="0,4,0,12" Minimum="0" Maximum="255" Value="128" IsSnapToTickEnabled="True" TickFrequency="1" />
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Tilt" />
                                <Slider x:Name="LyreTiltSlider" Margin="0,4,0,12" Minimum="0" Maximum="255" Value="118" IsSnapToTickEnabled="True" TickFrequency="1" />
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Vitesse" />
                                <Slider x:Name="LyreSpeedSlider" Margin="0,4,0,12" Minimum="0" Maximum="255" Value="42" />
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Intensité" />
                                <Slider x:Name="LyreDimmerSlider" Margin="0,4,0,12" Minimum="0" Maximum="255" Value="220" />
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Strobe" />
                                <Slider x:Name="LyreStrobeSlider" Margin="0,4,0,16" Minimum="0" Maximum="255" Value="0" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Couleur" />
                                <UniformGrid Columns="2" Margin="0,6,0,14">
                                    <RadioButton x:Name="LyreRedRadio" GroupName="LyreColor" IsChecked="True" Content="Rouge" Foreground="#FF766F" />
                                    <RadioButton x:Name="LyreOrangeRadio" GroupName="LyreColor" Content="Orange" Foreground="#FFAE58" />
                                </UniformGrid>

                                <Button Height="36" Margin="0,0,0,8" Background="#18394A" BorderBrush="#3D9CC0"
                                        Click="OnSendLyreCommandClick" Content="ENVOYER AUX LYRES" />
                                <Button Height="32" Click="OnBlackoutLyresClick" Content="ÉTEINDRE LES LYRES" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="ShapesTab" Header="FORMES ORGANIQUES">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock x:Name="ShapesClipTextBlock"
                                           Margin="0,0,0,12"
                                           Foreground="#DADADA"
                                           Text="Aucun clip selectionne" />

                                <TextBlock x:Name="ShapeWorkflowTextBlock"
                                           Margin="0,0,0,12"
                                           Foreground="#AFAFAF"
                                           Text="Clique une forme, puis déplace son arrivée pour l'animer" />

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Souris dans le preview" />
                                <ComboBox x:Name="ShapeEditModeComboBox"
                                          Margin="0,4,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Déplacer le départ" Tag="Position" />
                                    <ComboBoxItem Content="Déplacer l'arrivée" Tag="Movement" />
                                    <ComboBoxItem Content="Redimensionner directement" Tag="Resize" />
                                    <ComboBoxItem Content="Tourner directement" Tag="Rotate" />
                                </ComboBox>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Rotation" />
                                    <TextBlock x:Name="RotationAngleTextBlock" Grid.Column="1" Foreground="#62E6FF" FontFamily="Consolas" Text="0°" />
                                </Grid>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Trajet" />
                                <ComboBox x:Name="MovementEffectComboBox"
                                          Margin="0,4,0,8"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Aucun" Tag="None" />
                                    <ComboBoxItem Content="Instantané" Tag="Snap" />
                                    <ComboBoxItem Content="Impact" Tag="Punch" />
                                    <ComboBoxItem Content="Très rapide" Tag="VeryFast" />
                                    <ComboBoxItem Content="Rapide" Tag="Fast" />
                                    <ComboBoxItem Content="Lent" Tag="Slow" />
                                    <ComboBoxItem Content="Fade" Tag="Fade" />
                                </ComboBox>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MovementDurationTextBlock"
                                                   Foreground="#AFAFAF"
                                                   FontFamily="Consolas"
                                                   Text="durée 0.000s" />
                                        <TextBlock x:Name="MovementOffsetTextBlock"
                                                   Foreground="#AFAFAF"
                                                   FontFamily="Consolas"
                                                   Text="arrivée dx 0 / dy 0" />
                                    </StackPanel>
                                    <Button x:Name="ResetMovementButton"
                                            Grid.Column="2"
                                            MinWidth="72"
                                            Height="28"
                                            Content="Remise 0" />
                                </Grid>

                                <UniformGrid Columns="3" Margin="0,0,0,14">
                                    <Button x:Name="ReplayMotionButton"
                                            Height="30"
                                            Margin="0,0,6,0"
                                            Content="Rejouer" />
                                    <Button x:Name="RedoMotionButton"
                                            Height="30"
                                            Margin="0,0,6,0"
                                            Content="Refaire" />
                                    <Button x:Name="ConfirmMotionButton"
                                            Height="30"
                                            Content="Confirmer" />
                                </UniformGrid>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}"
                                           Margin="0,0,0,12"
                                           Text="Créer une barre de forme" />

                                <Border Margin="0,0,0,14" Padding="12" CornerRadius="8"
                                        Background="#152235" BorderBrush="#36708B" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Foreground="#E7F5FF" FontWeight="SemiBold" Text="ATELIER — Créer ma forme" />
                                        <TextBlock Margin="0,3,0,10" Foreground="#8195AE" FontSize="10" TextWrapping="Wrap"
                                                   Text="Choisissez chaque caractéristique : la forme obtenue est construite à partir de vos réglages." />

                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Famille" />
                                        <ComboBox x:Name="CustomShapeTypeComboBox" Margin="0,4,0,8" SelectedIndex="0">
                                            <ComboBoxItem Content="Ondulations concentriques" Tag="Ripple" />
                                            <ComboBoxItem Content="Tracé cardiaque" Tag="Heartbeat" />
                                        </ComboBox>

                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Complexité" />
                                        <ComboBox x:Name="CustomShapeDensityComboBox" Margin="0,4,0,8" SelectedIndex="1">
                                            <ComboBoxItem Content="Simple — 3 éléments" Tag="3" />
                                            <ComboBoxItem Content="Équilibrée — 4 éléments" Tag="4" />
                                            <ComboBoxItem Content="Riche — 5 éléments" Tag="5" />
                                            <ComboBoxItem Content="Très riche — 6 éléments" Tag="6" />
                                        </ComboBox>

                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Épaisseur du trait" />
                                        <ComboBox x:Name="CustomShapeThicknessComboBox" Margin="0,4,0,8" SelectedIndex="1">
                                            <ComboBoxItem Content="Fine" Tag="1.4" />
                                            <ComboBoxItem Content="Moyenne" Tag="2.4" />
                                            <ComboBoxItem Content="Épaisse" Tag="4" />
                                        </ComboBox>

                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Aspect dessiné à la main" />
                                        <ComboBox x:Name="CustomShapeIrregularityComboBox" Margin="0,4,0,8" SelectedIndex="1">
                                            <ComboBoxItem Content="Propre" Tag="0.3" />
                                            <ComboBoxItem Content="Naturel" Tag="1.2" />
                                            <ComboBoxItem Content="Très organique" Tag="2.3" />
                                        </ComboBox>

                                        <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Variation du dessin" />
                                        <ComboBox x:Name="CustomShapeVariationComboBox" Margin="0,4,0,12" SelectedIndex="0">
                                            <ComboBoxItem Content="Variation A" Tag="0.35" />
                                            <ComboBoxItem Content="Variation B" Tag="1.15" />
                                            <ComboBoxItem Content="Variation C" Tag="2.25" />
                                            <ComboBoxItem Content="Variation D" Tag="3.4" />
                                        </ComboBox>

                                        <Button Height="34" Click="OnCreateCustomShapeClick" Content="CRÉER AVEC MES CHOIX" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,0,14" Padding="10" CornerRadius="8"
                                        Background="#202631" BorderBrush="#46536A" BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Taille de la forme sélectionnée" />
                                            <TextBlock Grid.Column="1" Foreground="#AFC7EE" Text="± 15 %" />
                                        </Grid>
                                        <UniformGrid Columns="2">
                                            <Button x:Name="ResizeSmallerButton" Style="{StaticResource ShapeButtonStyle}"
                                                    Height="30" Margin="0,0,5,0" Tag="0.85" Content="− Réduire" />
                                            <Button x:Name="ResizeLargerButton" Style="{StaticResource ShapeButtonStyle}"
                                                    Height="30" Margin="5,0,0,0" Tag="1.15" Content="+ Agrandir" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="36 formes dessinées à la main" />
                                <TextBox x:Name="ShapeSearchTextBox"
                                         Margin="0,6,0,8"
                                         Padding="10,7"
                                         ToolTip="Rechercher une forme"
                                         TextChanged="OnShapeFilterChanged" />
                                <ComboBox x:Name="ShapeCategoryComboBox"
                                          Margin="0,0,0,12"
                                          SelectedIndex="0"
                                          SelectionChanged="OnShapeFilterChanged">
                                    <ComboBoxItem Content="Toutes les catégories" Tag="All" />
                                    <ComboBoxItem Content="Traits au pinceau" Tag="Traits au pinceau" />
                                    <ComboBoxItem Content="Halos &amp; anneaux" Tag="Halos &amp; anneaux" />
                                    <ComboBoxItem Content="Gouttes" Tag="Gouttes" />
                                    <ComboBoxItem Content="Rubans &amp; ondes" Tag="Rubans &amp; ondes" />
                                    <ComboBoxItem Content="Spirales" Tag="Spirales" />
                                    <ComboBoxItem Content="Formes organiques" Tag="Formes organiques" />
                                </ComboBox>

                                <ListBox x:Name="ShapesItemsControl"
                                         Height="390"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ShapeButtonStyle}"
                                                    Margin="0,0,0,8"
                                                    Height="42"
                                                    HorizontalContentAlignment="Left"
                                                    Tag="{Binding}"
                                                    Click="OnShapeButtonClick">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DisplayName}" />
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#72839E" FontSize="10" Text="{Binding Category}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="AUDIO">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Margin="0,0,0,16"
                                       Foreground="#F4F4F4"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Musique" />

                            <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Fichier MP3" />
                            <TextBlock x:Name="AudioFileTextBlock"
                                       Margin="0,4,0,12"
                                       Foreground="#DADADA"
                                       Text="Aucun fichier selectionne"
                                       TextTrimming="CharacterEllipsis" />

                            <Button x:Name="SelectAudioButton"
                                    Height="34"
                                    Margin="0,0,0,8"
                                    Content="Ajouter un MP3" />
                            <Button x:Name="ConfirmAudioButton"
                                    Height="34"
                                    Margin="0,0,0,20"
                                    Content="Confirmer dans la timeline" />

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Volume" />
                                <TextBlock x:Name="AudioVolumeTextBlock"
                                           Grid.Column="1"
                                           Foreground="#DADADA"
                                           FontFamily="Consolas"
                                           Text="100%" />
                            </Grid>
                            <Slider x:Name="AudioVolumeSlider"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    Margin="0,0,0,18" />

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Fondu de fin" />
                                <TextBlock x:Name="AudioFadeOutTextBlock"
                                           Grid.Column="1"
                                           Foreground="#DADADA"
                                           FontFamily="Consolas"
                                           Text="Aucun" />
                            </Grid>
                            <Slider x:Name="AudioFadeOutSlider"
                                    Minimum="0"
                                    Maximum="10"
                                    Value="0"
                                    TickFrequency="0.5"
                                    IsSnapToTickEnabled="True" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="MEDIA">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Margin="0,0,0,16" Foreground="#F4F4F4" FontSize="16" FontWeight="SemiBold"
                                       Text="Image, GIF ou vidéo" />
                            <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Fichier" />
                            <TextBlock x:Name="MediaFileTextBlock" Margin="0,4,0,10" Foreground="#DADADA"
                                       Text="Aucun média sélectionné" TextTrimming="CharacterEllipsis" />
                            <Button x:Name="SelectMediaButton" Height="34" Margin="0,0,0,14" Content="Choisir un média…" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Début"/><TextBox x:Name="MediaStartTextBox" Margin="0,4,0,0" Text="0"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Durée"/><TextBox x:Name="MediaDurationTextBox" Margin="0,4,0,0" Text="3"/></StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource PropertyLabelStyle}" Text="Opacité" />
                            <Slider x:Name="MediaOpacitySlider" Margin="0,4,0,16" Minimum="0" Maximum="1" Value="1" />
                            <Button x:Name="AddMediaButton" Height="34" Content="Ajouter à l’animation" />
                            <TextBlock Margin="0,14,0,0" Foreground="#9EADBF" TextWrapping="Wrap"
                                       Text="Formats : PNG, JPG, BMP, GIF animé, MP4, WMV et AVI." />
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Row="2"
                          Grid.Column="0"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#2C2C2C"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="3"
                    Grid.Column="0"
                    Margin="12,0,12,12"
                    BorderBrush="#213E52"
                    BorderThickness="1"
                    Background="#090F18"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="12,8,12,6">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Foreground="#F3F7FF" FontSize="15" FontWeight="Bold" Text="MULTITRACK SESSION" />
                                <Border Margin="10,0,0,0" Padding="8,3" CornerRadius="10" Background="#172B35" BorderBrush="#2C6B7E" BorderThickness="1">
                                    <TextBlock Foreground="#62E6FF" FontSize="10" Text="LIVE EDIT" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Foreground="#8D9AAF" FontSize="11" Text="DURÉE" />
                                <TextBox x:Name="ProjectDurationTextBox" Width="58" Height="28" Margin="8,0" Text="30" />
                                <Button x:Name="ApplyDurationButton" MinWidth="70" Height="28" Content="APPLIQUER" />
                                <Button x:Name="ExtendTimelineButton" MinWidth="52" Height="28" Margin="6,0,0,0" Content="+10s" />
                            </StackPanel>
                        </Grid>

                        <WrapPanel>
                            <TextBox x:Name="TrackNameTextBox" Width="150" Height="30" Margin="0,0,6,6" Padding="8,4" Text="Nouvelle piste" />
                            <Button x:Name="AddTrackButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="＋ PISTE" />
                            <Button x:Name="RenameTrackButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="RENOMMER" />
                            <Button x:Name="DeleteTrackButton" Height="30" Margin="0,0,14,6" Padding="12,0" Content="SUPPRIMER" />
                            <Button x:Name="AddShapeLayerButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="＋ FORME" />
                            <Button x:Name="DuplicateClipToolbarButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="DUPLIQUER" />
                            <Button x:Name="InsertBeforeButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="＋ AVANT" />
                            <Button x:Name="InsertAfterButton" Height="30" Margin="0,0,6,6" Padding="12,0" Content="＋ APRÈS" />
                        </WrapPanel>
                    </StackPanel>

                    <local:TimelineView x:Name="TimelineControl" Grid.Row="1" Margin="12" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
