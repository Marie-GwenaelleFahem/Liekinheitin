<Window x:Class="Liekinheitin.CreativeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Liekinheitin.CreativeTool.Views"
        Title="Liekinheitin - CreativeTool" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- bouton Test orientation -->
            <RowDefinition Height="*" />
            <!-- zone de contenu -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <!-- 80% -->
                <ColumnDefinition Width="1*" />
                <!-- 20% : color picker + colonnes -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <!-- 50% : la grille -->
                <RowDefinition Height="3*" />
                <!-- 50% restants, libre -->
            </Grid.RowDefinitions>

            <views:PixelGridCanvasView x:Name="GridView"
                                        Grid.Column="0" Grid.Row="0" />

            <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
                <views:ColorPickerView DataContext="{Binding ColorPicker}" />
                <views:ColumnListView x:Name="ColumnList" DataContext="{Binding ColumnList}" Margin="0,8,0,0" />
                <views:ShapeListView DataContext="{Binding ShapeList}" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>