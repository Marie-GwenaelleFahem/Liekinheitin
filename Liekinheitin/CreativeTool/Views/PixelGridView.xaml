<UserControl x:Class="Liekinheitin.CreativeTool.Views.PixelGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid Background="#080808" ClipToBounds="True">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#303030"
                BorderThickness="1">
            <Grid Width="512" Height="512">
                <Image x:Name="PreviewImage"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       SnapsToDevicePixels="True" />

                <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
                    <Rectangle x:Name="SelectionBounds"
                               Visibility="Collapsed"
                               Stroke="#FFDA5A"
                               StrokeThickness="2"
                               StrokeDashArray="4,2" />
                    <Rectangle x:Name="TopLeftHandle" Width="10" Height="10" Fill="#FFFFFF" Stroke="#FF8A32" StrokeThickness="2" Visibility="Collapsed" />
                    <Rectangle x:Name="TopRightHandle" Width="10" Height="10" Fill="#FFFFFF" Stroke="#FF8A32" StrokeThickness="2" Visibility="Collapsed" />
                    <Rectangle x:Name="BottomLeftHandle" Width="10" Height="10" Fill="#FFFFFF" Stroke="#FF8A32" StrokeThickness="2" Visibility="Collapsed" />
                    <Rectangle x:Name="BottomRightHandle" Width="10" Height="10" Fill="#FFFFFF" Stroke="#FF8A32" StrokeThickness="2" Visibility="Collapsed" />
                    <Line x:Name="RotationStem" Stroke="#62E6FF" StrokeThickness="2" Visibility="Collapsed" />
                    <Ellipse x:Name="RotationHandle" Width="12" Height="12" Fill="#111827" Stroke="#62E6FF" StrokeThickness="2" Visibility="Collapsed" />
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</UserControl>
