<UserControl x:Class="Liekinheitin.CreativeTool.Views.FixtureInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200"
             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
    <Border Background="#FF2A2D34" BorderBrush="Gray" BorderThickness="1">
        <StackPanel Margin="8">
            <Border x:Name="TitleBar" Background="#FF3A3D44" Padding="4"
                    MouseLeftButtonDown="OnTitleBarMouseDown"
                    MouseMove="OnTitleBarMouseMove"
                    MouseLeftButtonUp="OnTitleBarMouseUp">
                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" />
            </Border>

            <StackPanel Margin="0,6,0,0" Visibility="{Binding IsProjector, Converter={StaticResource BoolToVisInverse}}">
                <TextBlock Text="Pan" Foreground="White" FontSize="10" />
                <Slider Minimum="0" Maximum="255" Value="{Binding Pan}" Margin="0,0,0,4" />
                <TextBlock Text="Tilt" Foreground="White" FontSize="10" />
                <Slider Minimum="0" Maximum="255" Value="{Binding Tilt}" Margin="0,0,0,4" />
                <TextBlock Text="Vitesse" Foreground="White" FontSize="10" />
                <Slider Minimum="0" Maximum="255" Value="{Binding Speed}" Margin="0,0,0,4" />
                <TextBlock Text="Intensité" Foreground="White" FontSize="10" />
                <Slider Minimum="0" Maximum="255" Value="{Binding Dimming}" Margin="0,0,0,4" />
                <TextBlock Text="Strobe" Foreground="White" FontSize="10" />
                <Slider Minimum="0" Maximum="255" Value="{Binding Strobe}" Margin="0,0,0,4" />
            </StackPanel>

            <TextBlock Text="R" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding R}" Margin="0,0,0,4" />
            <TextBlock Text="G" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding G}" Margin="0,0,0,4" />
            <TextBlock Text="B" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding B}" Margin="0,0,0,4" />
            <TextBlock Text="W" Foreground="White" FontSize="10" />
            <Slider Minimum="0" Maximum="255" Value="{Binding W}" />
            <Button Content="Keyframe" Click="OnKeyframeClick" Margin="0,8,0,0" Padding="4,2" />
        </StackPanel>
    </Border>
</UserControl>