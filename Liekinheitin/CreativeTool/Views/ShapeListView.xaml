<UserControl x:Class="Liekinheitin.CreativeTool.Views.ShapeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
        <StackPanel>
            <Border Background="{StaticResource PanelTitleBackground}" Padding="4">
                <TextBlock Text="Formes" Foreground="White" FontWeight="Bold" />
            </Border>

            <ListBox x:Name="ShapeListBox"
                     ItemsSource="{Binding Shapes}"
                     PreviewMouseLeftButtonDown="OnPreviewMouseDown"
                     PreviewMouseMove="OnPreviewMouseMove"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="4" Width="60">
                            <Path Data="{Binding Icon}" Fill="White"
                                  Stretch="Uniform" Width="24" Height="24"
                                  HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Border>
</UserControl>