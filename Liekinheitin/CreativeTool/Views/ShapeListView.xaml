<UserControl x:Class="Liekinheitin.CreativeTool.Views.ShapeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ListBox x:Name="ShapeListBox"
             ItemsSource="{Binding Shapes}"
             PreviewMouseLeftButtonDown="OnPreviewMouseDown"
             PreviewMouseMove="OnPreviewMouseMove">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Vertical" Margin="4" Width="60">
                    <Border BorderBrush="Gray" BorderThickness="1" Width="32" Height="32"
                            HorizontalAlignment="Center">
                        <Path Data="{Binding Icon}" Fill="White"
                              Stretch="Uniform" Width="24" Height="24" />
                    </Border>
                    <TextBlock Text="{Binding Label}" FontSize="10"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>